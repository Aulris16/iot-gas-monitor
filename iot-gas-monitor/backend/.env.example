# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=sqlite:///gas_monitor.db

# CORS
CORS_ORIGINS=http://localhost:5173

# MQTT Broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_TELEMETRY=gas/telemetry
MQTT_TOPIC_COMMANDS=gas/commands
